<UserControl x:Class="WPFUserControls.Controls.DatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFUserControls.Controls"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="40" d:DesignWidth="150" Width="{Binding Width}">
    <Grid DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:DatePicker}}">
        <TextBox x:Name="DateTextBox" Panel.ZIndex="0" Style="{StaticResource MaterialDesignFloatingHintTextBox}"  d:Text="21.12.2024" d:Foreground="White" FontSize="{Binding FontSize}" 
                 Foreground="{Binding Foreground}" Text="{Binding SelectedDate, StringFormat=dd.MM.yyyy}" PreviewTextInput="TextBox_PreviewTextInput"/>
        <Button Panel.ZIndex="1" Background="Transparent" BorderBrush="Transparent" Width="{Binding FontSize}" Height="{Binding FontSize}" Padding="0" Margin="0 0 0 9" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    md:DialogHost.DialogClosingAttached="CalendarDialogClosingEventHandler"
                    md:DialogHost.DialogOpenedAttached="CalendarDialogOpenedEventHandler"
                    Command="{x:Static md:DialogHost.OpenDialogCommand}">
            <Button.CommandParameter>
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Viewbox Stretch="Uniform">
                        <Calendar x:Name="Calendar"/>
                    </Viewbox>
                    <StackPanel
                          Grid.Row="1"
                          Margin="8"
                          HorizontalAlignment="Right"
                          Orientation="Horizontal">
                        <Button
            Command="{x:Static md:DialogHost.CloseDialogCommand}"
            CommandParameter="0"
            Content="CANCEL"
            Style="{StaticResource MaterialDesignFlatButton}" />
                        <Button
            Command="{x:Static md:DialogHost.CloseDialogCommand}"
            CommandParameter="1"
            Content="OK"
            Style="{StaticResource MaterialDesignFlatButton}" />
                    </StackPanel>
                </Grid>
            </Button.CommandParameter>
            <md:PackIcon Kind="Calendar" Width="{Binding FontSize}" Height="{Binding FontSize}" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center" d:Foreground="White" >
                <md:PackIcon.Style>
                    <Style TargetType="md:PackIcon">
                        <Setter Property="Foreground"  Value="{Binding Foreground}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=DateTextBox, Path=IsFocused}" Value="True">
                                <Setter Property="Foreground"  Value="{StaticResource PrimaryColorBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ElementName=DateTextBox, Path=IsMouseOver}" Value="True">
                                <Setter Property="Foreground"  Value="{StaticResource PrimaryColorBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </md:PackIcon.Style>
            </md:PackIcon>
        </Button>
    </Grid>
</UserControl>
