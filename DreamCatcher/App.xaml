<Application x:Class="DreamCatcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DreamCatcher"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Startup="OnStartup">
    <Application.Resources>
		<ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themas/DarkThema.xaml" />

                <md:CustomColorTheme BaseTheme="Dark" PrimaryColor="{StaticResource ThirdColor}"  SecondaryColor="{StaticResource SecondaryColor}"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />

                <ResourceDictionary Source="Styles/BaseStyle.xaml"/>
                <ResourceDictionary Source="Styles/Pickers.xaml"/>
                <ResourceDictionary Source="Styles/ScrollbarStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
    </Application.Resources>
</Application>
